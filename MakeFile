.PHONY: proto build test run-server clean

# Regenerate Go code from proto/kv.proto
proto:
	protoc --go_out=pkg/pb --go_opt=paths=source_relative \
	--go-grpc_out=pkg/pb --go-grpc_opt=paths=source_relative \
	--proto_path=proto \
	kv.proto

# Build all binaries
build:
	go build -o bin/server ./cmd/server
	go build -o bin/client ./cmd/client

# Run all tests including integration tests
test:
	go test ./... -race -timeout 30s

# Run a single node server for local testing
run-server:
	go run ./cmd/server --port=7001 --name=NodeA --data-dir=/tmp/nodeA

# Clean generated files and binaries
clean:
	rm -rf bin/ pkg/pb/*.go